<Page x:Class="AppKeyPass.Pages.Registration"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppKeyPass.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Registration">

    <Grid>
        <StackPanel Width="200" Height="250">
            <Label Content="Имя:" Height="25"/>
            <TextBox x:Name="tbName" Height="25"/>
            <Label Content="Фамилия:" Height="25"/>
            <TextBox x:Name="tbSurname" Height="25"/>
            <Label Content="Логин:" Height="25"/>
            <TextBox x:Name="tbLogin" Height="25"/>
            <Label Content="Пароль:" Height="25"/>
            <PasswordBox x:Name="tbPassword" Height="25"/>
            <Button Click="BtnRegistration" Content="Зарегистрироваться" Height="25"
                Width="135" Margin="0,10,0,0" HorizontalAlignment="Right"/>
        </StackPanel>
        <Button Click="ToLogin" Content="Вход" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10" Width="100" Height="25"/>
    </Grid>
</Page>
